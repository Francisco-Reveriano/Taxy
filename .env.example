# Personal API Keys
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
MISTRAL_API_KEY="your-mistral-api-key"

# LLM Models
OCR_MODEL="mistral-ocr-2512"
ANTHROPIDC_ADVANCE_LLM_MODEL="claude-opus-4-6"
ANTHROPIC_MEDIUM_LLM_MODEL="claude-sonnet-4-6"
ANTHROPIC_LOW_LLM_MODEL="claude-haiku-4-5"
OPENAI_VERY_ADVANCE_LLM_MODEL="gpt-4o"
OPENAI_ADVANCE_LLM_MODEL="gpt-4o"
OPENAI_MEDIUM_LLM_MODEL="gpt-4o-mini"

# Vector Store
TAX_VECTOR_STORE="your-vector-store-id"

# Telemetry
# Traces always saved locally to backend/traces/ (no external service needed)
# Set OTEL_EXPORTER_ENDPOINT to send traces to Jaeger/collector too (optional)
OTEL_EXPORTER_ENDPOINT=""
OTEL_CONSOLE_EXPORT="false"

# SSL verification (set to false if behind a corporate proxy with self-signed certs)
MISTRAL_VERIFY_SSL="true"

# Agent Settings
TODO_MAX_ITERATIONS="20"
CONTEXT_WINDOW_THRESHOLD="0.75"

# Form 1040 output
FORM_1040_TEMPLATE_PATH="/Users/Francisco_Reveriano/Downloads/f1040.pdf"
